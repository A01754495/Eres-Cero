:root {
}

.root {
    width: 100%;
    height: 100%;
}

/*  fondo */
.fondo {
    position: absolute;
    width: 100%;
    height: 100%;
}

/*  botón perder */
.boton-perder {
    position: absolute;
    bottom: 40px;
    right: 40px;

    width: 180px;
    height: 60px;

    font-size: 20px;
    color: white;

    background-color: white;
    unity-text-align: middle-center;
}