:root {
}

.root {
    width: 100%;
    height: 100%;
    justify-content: center;
    align-items: center;
}

.panel {
    width: 100%;
    height: 100%;
    align-items: center;
    justify-content: center;
}

.titulo-ranking {
    font-size: 48px;
    color: white;
    unity-text-align: middle-center;
    margin-bottom: 20px;
    -unity-background-image-tint-color: rgba(0, 0, 0, 0.99);
    background-color: rgba(0, 0, 0, 0.91);
}

.boton-ranking {
    width: 260px;
    height: 80px;
    font-size: 28px;
    color: rgb(68, 68, 68);
    background-color: rgb(240, 240, 240);
}

.boton:hover {
    scale: 1.2 1.2;
    transition-duration: 0.5s;
    transition-delay: 0s;
}

.lista {
    width: 60%;
    align-self: center;
    flex-grow: 1;
    position: absolute;
    top: 30%;
    left: 25%;
    right: 25%;
    bottom: 30%;
    background-color: rgba(0, 0, 0, 0.51);
    -unity-font-style: bold;
    font-size: 20px;
}
